{
  "name": "@pacexy/eslint-config",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "description": "ESLint config based on @antfu/eslint-config",
  "author": "pacexy <pacexy@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/pacexy/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pacexy/eslint-config.git"
  },
  "bugs": "https://github.com/pacexy/eslint-config/issues",
  "keywords": [
    "eslint-config"
  ],
  "main": "src/index.js",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "pnpm run build:typegen",
    "build:inspector": "eslint-config-inspector build",
    "build:typegen": "node scripts/typegen.js",
    "dev": "eslint-config-inspector --open false",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "postversion": "git push --follow-tags",
    "prepare": "simple-git-hooks",
    "update": "corepack use pnpm@latest && pnpm update --latest"
  },
  "dependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "local-pkg": "^1.1.2"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/config-inspector": "^2.0.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-google-translate": "^1.0.4",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-typegen": "^2.3.1",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
